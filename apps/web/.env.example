# ─────────────────────────────────────────────────────────────────────────────
# HotelVALORA — apps/web environment variables
#
# Copy to `.env.local` for local dev. In production (Vercel / Hetzner / etc.),
# set these via the platform's environment-variable UI.
# ─────────────────────────────────────────────────────────────────────────────

# Mapbox GL access token for the CompSet map (/compset, /report/competitive-set).
# Without this the map renders blank. Get one at:
#   https://account.mapbox.com/access-tokens/
# Marked NEXT_PUBLIC_ because the token is exposed to the browser by design
# (Mapbox's standard pattern — restrict the token to your domain via the
# Mapbox dashboard).
NEXT_PUBLIC_MAPBOX_TOKEN=

# Backend API base URL. Leave empty in environments without a deployed API
# — the app currently uses mock data only and never hits a real API.
# When the FastAPI backend ships, set to e.g. https://api.hotelvalora.com/api/v1
NEXT_PUBLIC_API_URL=

# Optional — set to "standalone" only when building for a Docker image.
# Vercel / Cloudflare Pages do NOT need this (they auto-handle serverless).
# NEXT_OUTPUT=standalone

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Required signing secret. Generate with:
#   openssl rand -base64 32
# In Vercel: set it once in the project settings; the platform injects it as
# AUTH_SECRET (or legacy NEXTAUTH_SECRET — Auth.js v5 reads both).
AUTH_SECRET=

# Public base URL of the deployed app — Auth.js uses it to mint absolute
# callback URLs. Auto-detected on Vercel from VERCEL_URL; only set this
# locally for non-Vercel deploys (custom domain on Hetzner, etc.).
AUTH_URL=

# Feature flag — when "true", middleware enforces login on /settings,
# /library, /report, /dashboard. Leave empty or set to "false" until real
# OAuth credentials are configured (otherwise every authenticated route
# redirects to /login).
AUTH_ENABLED=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth — https://www.linkedin.com/developers/apps
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Apple Sign In — https://developer.apple.com/account/resources/identifiers/serviceId
# CLIENT_ID is the Service ID; CLIENT_SECRET is the .p8 private key payload
# (or the short-lived JWT minted from it — Auth.js handles the JWT mint
# when given the raw key in production).
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Resend (transactional email) ────────────────────────────────────────────
# Resend API key — https://resend.com/api-keys
# Required for the Library "Schedule a Tour" CTA on top-promoted reports.
# Server-only — never expose to the browser.
RESEND_API_KEY=

# Default sender — must be either:
#   1. an address on a domain verified in your Resend account (production), or
#   2. "onboarding@resend.dev" (sandbox — only delivers to the account owner)
# Format: "Display Name <addr@domain.com>"
RESEND_FROM_EMAIL=

# ─── Supabase ────────────────────────────────────────────────────────────────
# Where to find these (Supabase dashboard → Settings → API):
#   - Project URL            → NEXT_PUBLIC_SUPABASE_URL
#   - anon (public) key      → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role (secret)  → SUPABASE_SERVICE_ROLE_KEY  (NEVER expose)
#
# NEXT_PUBLIC_* are exposed to the browser by design — anon key is safe
# IFF Row Level Security policies are in place (see docs/database/schema.sql).
# service_role bypasses RLS and must remain server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Hospitality Intelligence — Authenticated Sources (Phase 2.5+) ───────────
# Three-tier credential model. See docs/integrations/hosteltur.md and
# migration docs/database/migrations/0009_intelligence_source_sessions.sql.
#
# RULES
#   1. All values below MUST be marked "Sensitive" in Vercel and scoped to
#      Production only (never Preview, never Development).
#   2. Never commit real values. This file documents NAMES only.
#   3. Never echo these in code, logs, errors, audit rows, or chat.
#   4. Rotate quarterly + immediately on any incident.

# ─── Session-state encryption (KEK for AES-256-GCM at rest) ──────────────────
# 32-byte symmetric key that wraps every row of
# public.intelligence_source_sessions before it lands in Supabase.
# Generate ONCE per environment:
#   openssl rand -base64 32
# Store in Vercel + .env.local. Lose this and every stored session is
# unrecoverable (but credentials are intact — just re-run the refresh
# script to mint a new session).
INTELLIGENCE_SESSION_ENC_KEY=
# Identifier of the active KEK. Default "v1". Bump to "v2" only when
# rotating — old rows with enc_key_id="v1" continue to decrypt with the
# legacy key (kept in INTELLIGENCE_SESSION_ENC_KEY_V1 after rotation).
INTELLIGENCE_SESSION_ENC_KEY_ID=v1

# Server-only authorization token for the future
# POST /api/agents/refresh-session endpoint (Phase 3 / 4).
# Separate from CRON_SECRET + INGESTION_AUDIT_TOKEN — different blast radius.
# Generate with:
#   openssl rand -hex 32
INTELLIGENCE_REFRESH_TOKEN=

# ─── Hosteltur (validation source — Phase 2.5) ───────────────────────────────
# Subscriber credentials. T1 in the credential model — touched ONLY by:
#   - apps/web/scripts/refresh-intel-session.mjs (operator CLI)
#   - future POST /api/agents/refresh-session (Phase 3+)
# Never read by the Market Intelligence Agent, never logged, never
# persisted to Supabase. The agent only reads the encrypted session
# row that this credential produces.
HOSTELTUR_USERNAME=
HOSTELTUR_PASSWORD=
# Optional override — only set if Hosteltur moves its login URL.
# Default: https://www.hosteltur.com/login
HOSTELTUR_LOGIN_URL=
