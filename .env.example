# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="HOTEL VALORA"
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-64-char-secret

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hotelvalora
POSTGRES_USER=valora
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://valora:change-me-strong-password@localhost:5432/hotelvalora
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Object Storage (S3 / MinIO) ──────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_DOCUMENTS=valora-documents
S3_BUCKET_EXPORTS=valora-exports
S3_REGION=us-east-1

# ─── CoStar Integration ───────────────────────────────────────────────────────
COSTAR_API_KEY=
COSTAR_API_BASE_URL=https://api.costar.com/v1
COSTAR_USERNAME=
COSTAR_PASSWORD=

# ─── Financial Engine ─────────────────────────────────────────────────────────
DEFAULT_DISCOUNT_RATE=0.10
DEFAULT_TERMINAL_CAP_RATE=0.07
DEFAULT_PROJECTION_YEARS=10
DEFAULT_CURRENCY=USD

# ─── Frontend (Next.js public vars — prefix NEXT_PUBLIC_) ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME="HOTEL VALORA"
NEXT_PUBLIC_APP_ENV=development

# ─── Monitoring / Observability ───────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Email (transactional) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_ADDRESS=noreply@hotelvalora.com
EMAILS_FROM_NAME="HOTEL VALORA"
