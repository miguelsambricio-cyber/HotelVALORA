# ─── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production

# ─── Node / pnpm ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.npm/
dist/
.next/
out/
build/
*.tsbuildinfo
.turbo/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg

# ─── Alembic ──────────────────────────────────────────────────────────────────
# Keep versions tracked; ignore only auto-generated temp files
alembic/versions/*.pyc

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
vite.out.log
vite.err.log

# ─── Docker ───────────────────────────────────────────────────────────────────
.docker/

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.coverage
htmlcov/
junit.xml

# ─── Secrets / Keys ───────────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
secrets/
# MCP server config carries per-operator API keys (RapidAPI, etc).
# Each operator regenerates locally · never commit.
.mcp.json

# ─── Uploads / Exports ────────────────────────────────────────────────────────
uploads/
exports/
tmp/
.vercel

# ─── Diagnostic probes (ephemeral · raw API dumps, never tracked) ────────────
.smoke/

# ─── Operator-sensitive working files (NEVER track) ──────────────────────────
# Financial models (investor-facing P&L, valuation scenarios, deal terms).
HotelVALORA_Modelo_Financiero.xlsx
*Modelo_Financiero*.xlsx
# Operator-side provisioning helpers (handle secrets via stdin · live keys
# may transit through these scripts even if not stored in plaintext).
scripts/provision-*-keys.ps1
scripts/provision-*-keys.sh

# ─── Transient artifacts from pnl import (regenerable from canonical Excel) ──
# Plan JSON + bulk SQL + chunked SQL + scaffold output.
services/costar/MASTER/_pnl_upsert*
services/costar/MASTER/COSTAR_MASTER_FINANCIALS.scaffold.xlsx

# ─── CONTACTOS DATASITE (institutional relationship intelligence · PII) ──────
# Datasite Outreach exports contain emails, phones, LinkedIn URLs, internal
# notes, and bid history. Never commit any of it to git. The README at
# CONTACTOS DATASITE/README.md is the only thing that's safe to track.
CONTACTOS DATASITE/incoming/
CONTACTOS DATASITE/old/
CONTACTOS DATASITE/master/
CONTACTOS DATASITE/reports/
CONTACTOS DATASITE/google-contacts/
CONTACTOS DATASITE/*.xlsx
CONTACTOS DATASITE/*.xlsm
CONTACTOS DATASITE/*.csv
CONTACTOS DATASITE/*.vcf
CONTACTOS DATASITE/.gmail-batch-baseline.txt
# README.md is the only safe-to-commit artifact under this tree
!CONTACTOS DATASITE/README.md

# Excel lock files (created when operator has master open in Excel)
services/costar/MASTER/~$*.xlsx
