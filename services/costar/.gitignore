# services/costar — institutional hospitality market intelligence workspace
#
# Same philosophy as services/transactions/.gitignore: git tracks the CONTRACT
# (directory structure + master canonical datasets + templates + schemas),
# NOT the day-to-day data. Real CoStar exports, processed archives, staging
# artefacts and run logs stay local + auditable but never travel through
# commits.

# Inbound raw imports (operator drops these — never commit).
# Governance rule (2026-05-14): every workspace has exactly ONE pair —
#   INPUT/  → files pending ingestion (operational queue)
#   OLD/    → files successfully merged into the master (audit trail)
# Legacy `old.<workspace>/` folders are kept around for historical audit
# but the pipeline only writes to OLD/.
PAIS/INPUT/*
!PAIS/INPUT/.gitkeep
PAIS/OLD/*
!PAIS/OLD/.gitkeep
PAIS/old.pais/*
!PAIS/old.pais/.gitkeep

MERCADO/INPUT/*
!MERCADO/INPUT/.gitkeep
MERCADO/OLD/*
!MERCADO/OLD/.gitkeep
MERCADO/old.mercado/*
!MERCADO/old.mercado/.gitkeep

SUBMERCADO/INPUT/*
!SUBMERCADO/INPUT/.gitkeep
SUBMERCADO/OLD/*
!SUBMERCADO/OLD/.gitkeep
SUBMERCADO/old.submercado/*
!SUBMERCADO/old.submercado/.gitkeep

# HOTELESperMARKET replaces the retired CLASS folder (renamed on disk 2026-05-14).
# Operator-dropped hotel-inventory exports stay local + auditable but never commit.
HOTELESperMARKET/INPUT/*
!HOTELESperMARKET/INPUT/.gitkeep
HOTELESperMARKET/INPUT/**/*
!HOTELESperMARKET/INPUT/**/.gitkeep
HOTELESperMARKET/OLD/*
!HOTELESperMARKET/OLD/.gitkeep
HOTELESperMARKET/old.hotelspermarket/*
!HOTELESperMARKET/old.hotelspermarket/.gitkeep

# Staging — failed parses, manual-review queue, temp normalisation files
staging/failed/*
!staging/failed/.gitkeep

staging/review/*
!staging/review/.gitkeep

staging/temp/*
!staging/temp/.gitkeep

# Operational run logs
logs/*
!logs/.gitkeep

# Local-only working copies of the masters
MASTER/*.bak
MASTER/*~
MASTER/.~lock.*

# v1.2/v1.3 outputs — snapshot.json + operator corrections + applied audit log
# all stay local (same posture as INPUT files).
MASTER/snapshot.json
corrections/*.jsonl
corrections-applied/*.jsonl

# Python pipeline runtime artefacts
scripts/__pycache__/
scripts/*.pyc
scripts/.pytest_cache/
